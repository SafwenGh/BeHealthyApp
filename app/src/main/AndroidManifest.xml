<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.behealthypp">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Behealthypp">

        <!-- TP5: LOGIN ACTIVITY (Main Activity - écran de démarrage) -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- TP5: LISTE RECETTES ACTIVITY -->
        <activity
            android:name=".ListRecettesActivity"
            android:exported="false" />

        <!-- TP3: PROFILE ACTIVITY (Écran d'accueil original) -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- TP3: MAIN ACTIVITY (Premier écran du TP3) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- TP4: CATALOGUE ACTIVITY -->
        <activity
            android:name=".CatalogueActivity"
            android:exported="false" />

        <!-- Ajoutez d'autres activités ici si nécessaire -->

    </application>

</manifest>